{
  "name": "@tfs-ucmp/shared",
  "version": "1.0.0",
  "description": "Shared services, providers, and utilities for Arrow monorepo",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./services": "./src/services/index.ts",
    "./services/*": "./src/services/*.ts",
    "./providers": "./src/providers/index.ts",
    "./providers/*": "./src/providers/*.tsx",
    "./utils": "./src/utils/index.ts",
    "./utils/*": "./src/utils/*.ts",
    "./hooks": "./src/hooks/index.ts",
    "./hooks/*": "./src/hooks/*.ts",
    "./types": "./src/types/index.ts"
  },
  "scripts": {
    "lint": "biome check .",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf node_modules .turbo dist"
  },
  "dependencies": {},
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.2"
  }
}
