# API Configuration
NEXT_PUBLIC_API_URL=https://api.example.com
API_SECRET_KEY=your-secret-key-here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Authentication
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Feature Flags
NEXT_PUBLIC_FEATURE_FLAG_EXAMPLE=true

# Fingerprint.js Pro Configuration
NEXT_PUBLIC_FINGERPRINT_API_KEY=your_public_api_key_here

# Fingerprint.js Proxy (Bypass Ad Blockers)
# Set to true to route Fingerprint.js requests through /api/fpjs proxy
# This bypasses ad blockers that block fingerprinting domains
NEXT_PUBLIC_USE_FPJS_PROXY=false

# Fingerprint.js Server API (Secret Key - Server-side only)
# Get this from: https://dashboard.fingerprint.com → API Keys → Secret API Key
FINGERPRINT_SECRET_API_KEY=your_secret_api_key_here

# Used by client-side event tracking
NEXT_PUBLIC_EVENT_SERVICE_URL=/api/events

# Fingerprint Service Configuration
FINGERPRINT_SERVICE_URL=
